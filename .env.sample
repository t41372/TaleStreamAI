# -----------------------------------------------------------------------------
# 通用设置 (General Settings)
# -----------------------------------------------------------------------------

# 书籍来源：可以是起点ID或本地.txt文件路径 (默认为: test_novel.txt)
BOOK_SOURCE=test_novel.txt

# 为本地文件指定一个自定义的书籍ID (默认为文件名)，用于区分不同的项目文件夹
# CUSTOM_BOOK_ID=my-epic-story

# 如果需要爬取需要登录的网站（如起点），请在此填入你的Cookie
COOKIE=

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - 分镜生成 (Storyboard Generation)
# -----------------------------------------------------------------------------
# 用于将小说原文转换成结构化分镜脚本的LLM

STORYBOARD_API_KEY=<api_key>
STORYBOARD_API_URL=https://tbai.xin/v1
STORYBOARD_MODEL=deepseek-r1

# 分镜LLM处理文本时，用于分块的最大token数 (默认为: 8000)
# 根据你使用的模型上下文窗口大小进行调整
STORYBOARD_MAX_TOKENS=4000

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - 提示词优化 (Prompt Refinement)
# -----------------------------------------------------------------------------
# 用于将中文镜头语言优化成高质量英文AI绘画提示词的LLM

PROMPT_API_KEY=<api_key>
PROMPT_API_URL=https://tbai.xin/v1
PROMPT_MODEL=deepseek-v3

# 提示词优化LLM的最大token数 (默认为: 8000)
# PROMPT_MAX_TOKENS=8000

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - 性能与网络 (Performance & Network)
# -----------------------------------------------------------------------------

# 所有LLM API调用的最大并发线程数 (默认为: 3)
LLM_THREADS=30

# LLM API 请求超时时间(秒) (默认为: 120)
LLM_TIMEOUT=120

# LLM API 请求失败后的重试次数 (默认为: 3)
LLM_RETRY_ATTEMPTS=3

# -----------------------------------------------------------------------------
# 图像生成 (Image Generation)
# -----------------------------------------------------------------------------

# 生成图片的宽度 (默认为: 1024)
IMAGE_WIDTH=1024

# 生成图片的高度 (默认为: 1024)
IMAGE_HEIGHT=1440

# 全局追加到每个图像提示词后的风格修饰词
IMAGE_STYLE_PROMPT="cinematic, anime sytle, lighting, detailed, illustration, 8k"

# 图像生成并发限制
IMAGE_THREADS=1

# -----------------------------------------------------------------------------
# 音频生成 (Audio Generation)
# -----------------------------------------------------------------------------

# Edge TTS 使用的语音 (默认为: zh-CN-YunxiNeural)
EDGE_TTS_VOICE=zh-CN-YunxiNeural

# 音频生成任务的最大并发数 (默认为: 5)
AUDIO_THREADS=5

# -----------------------------------------------------------------------------
# 视频合成 (Video Synthesis)
# -----------------------------------------------------------------------------

# 使用moviepy合成视频片段时的线程数 (默认为: 4)
VIDEO_THREADS=4

# 最终视频的宽度 (默认为: 750)
VIDEO_WIDTH=1080

# 最终视频的高度 (默认为: 1280)
VIDEO_HEIGHT=1920

# -----------------------------------------------------------------------------
# 系统与日志 (System & Logging)
# -----------------------------------------------------------------------------

# 是否开启详细日志 (true/false) (默认为: true)
VERBOSE_LOGGING=true 