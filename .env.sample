# TaleStreamAI 环境变量配置文件
# 将此文件复制为 .env 并填入实际的配置值

# -----------------------------------------------------------------------------
# 通用配置
# -----------------------------------------------------------------------------
# 书籍源文件或URL
BOOK_SOURCE=test_novel.txt
# 自定义书籍ID（可选）
CUSTOM_BOOK_ID=
# 访问需要登录的网站时的cookie（可选）
COOKIE=

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - 分镜生成
# -----------------------------------------------------------------------------
# 用于生成分镜脚本的主要LLM配置
STORYBOARD_API_KEY=<your_api_key>
STORYBOARD_API_URL=https://api.openai.com/v1
STORYBOARD_MODEL=gpt-4o-mini
STORYBOARD_MAX_TOKENS=8000

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - 图像提示词生成
# -----------------------------------------------------------------------------
# 用于生成图像提示词的LLM配置
PROMPT_API_KEY=<your_api_key>
PROMPT_API_URL=https://api.openai.com/v1
PROMPT_MODEL=gpt-4o-mini
PROMPT_MAX_TOKENS=8000

# -----------------------------------------------------------------------------
# 大语言模型 (LLM) - JSON 自动修复
# -----------------------------------------------------------------------------
# 用于在LLM返回格式错误的JSON时，自动尝试修复的专用LLM。
# 如果留空，将默认使用分镜LLM的配置。
JSON_REPAIR_API_KEY=<your_api_key>
JSON_REPAIR_API_URL=https://api.openai.com/v1
JSON_REPAIR_MODEL=gpt-4o-mini
JSON_REPAIR_MAX_TOKENS=2048

# -----------------------------------------------------------------------------
# LLM 性能配置
# -----------------------------------------------------------------------------
# LLM 并发线程数
LLM_THREADS=3
# LLM API 请求超时时间(秒)
LLM_TIMEOUT=120
# LLM API 重试次数
LLM_RETRY_ATTEMPTS=3

# -----------------------------------------------------------------------------
# 图像生成配置
# -----------------------------------------------------------------------------
IMAGE_WIDTH=1024
IMAGE_HEIGHT=1024
IMAGE_STYLE_PROMPT=cinematic, dramatic lighting, detailed, illustration, anime style, 8k
IMAGE_THREADS=1

# -----------------------------------------------------------------------------
# 音频生成配置
# -----------------------------------------------------------------------------
# Edge TTS 语音
EDGE_TTS_VOICE=zh-CN-YunxiNeural
# 音频生成最大并发数
AUDIO_THREADS=5

# -----------------------------------------------------------------------------
# 视频生成配置
# -----------------------------------------------------------------------------
# 视频生成线程数
VIDEO_THREADS=4
# 视频宽度
VIDEO_WIDTH=750
# 视频高度
VIDEO_HEIGHT=1280

# -----------------------------------------------------------------------------
# 其他配置
# -----------------------------------------------------------------------------
# 是否开启详细日志
VERBOSE_LOGGING=true
