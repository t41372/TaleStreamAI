COOKIE=

# 大模型配置 - OpenAI兼容格式
# 用於分鏡生成的模型配置
STORYBOARD_API_KEY=
STORYBOARD_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/
STORYBOARD_MODEL=gemini-2.0-flash

# 用於圖片提示詞生成的模型配置
PROMPT_API_KEY=
PROMPT_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
PROMPT_MODEL=deepseek-v3

# 備用：阿里雲通義千問配置 (兼容模式)
AL_API_KEY=
AL_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 備用：Gemini API配置
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 文生图配置 - 使用 Flux API
FLUX_WIDTH=1024
FLUX_HEIGHT=1024
FLUX_MODEL=flux
FLUX_SEED=
FLUX_ENHANCE=false

# 高清修复配置
UPSCALY_ENABLE=false
UPSCAYL_SCALE=4
UPSCAYL_MODEL=realesr-animevideov3-x4
UPSCALY_FILE_TYPE=jpg

# Edge TTS 配置
EDGE_TTS_VOICE=zh-CN-YunxiNeural     # Edge TTS 语音
AUDIO_THREADS=5                       # 音频生成最大并发数
USE_ASYNC_AUDIO=true                  # 是否使用异步音频生成

# 分段视频生成配置
VIDEO_THREADS=4         # 视频生成线程数
PORTRAIT_MODE=True      # 是否是竖屏模式
VIDEO_WIDTH=750         # 视频宽度
VIDEO_HEIGHT=1280       # 视频高度
MOVE_DISTANCE=0.1       # 移动距离 倍率
MOVE_SPEED=1.0          # 移动速度
ENTRANCE_EFFECT=True    # 入场效果
ENTRANCE_DURATION=0.2   # 入场持续时间
AUDIO_SPEED=1.0         # 音频速度 (效果不好)
