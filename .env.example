COOKIE=

# 大模型配置
AL_API_KEY=
AL_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Gemini API Key
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Edge-TTS 配置
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural  # 默认中文女声
EDGE_TTS_RATE=+0%                    # 语速调整
EDGE_TTS_PITCH=+0Hz                  # 音调调整
EDGE_TTS_CONCURRENT=4                # 最大并发数

# Flux 图像生成配置 (Pollinations.ai)
FLUX_MODEL=flux                      # 图像生成模型
FLUX_WIDTH=1024                      # 图像宽度
FLUX_HEIGHT=1024                     # 图像高度
FLUX_ENHANCE=false                   # 是否增强提示词
FLUX_SAFE=false                      # 是否启用安全过滤
FLUX_NOLOGO=false                    # 是否移除logo

# 高清修复配置
UPSCAYL_SCALE = 4
UPSCAYL_MODEL = realesr-animevideov3-x4
UPSCALY_FILE_TYPE = jpg

# 分段视频生成配置
VIDEO_THREADS=4         # 视频生成线程数
PORTRAIT_MODE=True      # 是否是竖屏模式
VIDEO_WIDTH=750         # 视频宽度
VIDEO_HEIGHT=1280       # 视频高度
MOVE_DISTANCE=0.1       # 移动距离 倍率
MOVE_SPEED=1.0          # 移动速度
ENTRANCE_EFFECT=True    # 入场效果
ENTRANCE_DURATION=0.2   # 入场持续时间
AUDIO_SPEED=1.0         # 音频速度 (效果不好)
