from dataclasses import dataclass, field
from pathlib import Path
from typing import Optional


@dataclass
class Shot:
    """
    表示一个独立的分镜（或镜头）。
    这是我们流水线中处理的基本工作单元。
    """

    # 核心内容
    shot_id: int
    chapter_index: int
    original_text: str

    # 生成的数据 (最终使用的提示词)
    image_prompt: Optional[str] = None

    # 生成的资产路径
    storyboard_path: Optional[Path] = None  # 指向分镜脚本JSON文件的路径
