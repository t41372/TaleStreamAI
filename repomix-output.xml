                            log_debug(f"圖片 {image_path} 高清修復成功")
                            # 更新进度条
                            pbar.update(1)
                            # 删除log文件
                            delete_log_file()
                        else:
                            # 重试
                            retry_count = 0
                            while retry_count < 3:
                                log_debug(
                                    f"重試高清修復圖片 {image_path} (第 {retry_count + 1}/3 次)"
                                )
                                upscale_result = upscale_image(str(image_path))
