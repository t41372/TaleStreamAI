                                    # 更新进度条
                                    pbar.update(1)
                                    # 删除log文件
                                    delete_log_file()
                                    break
                                retry_count += 1

                            if retry_count >= 3:
                                log_error(
                                    f"圖片 {image_path} 高清修復失敗，已重試 3 次"
                                )
                                pbar.update(1)
                    else:
