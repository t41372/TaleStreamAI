    def get_full_id(self) -> str:
        """返回唯一的镜头ID，格式为 '章节-镜头'"""
        return f"{self.chapter_index}-{self.shot_id}"


@dataclass
class Chapter:
    """表示一个完整的章节，包含多个分镜。"""

    index: int
    content: str
