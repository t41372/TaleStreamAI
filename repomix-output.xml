                            if file_size_mb > 2:
                                log_debug(
                                    f"圖片 {image_path} 大小 {file_size_mb:.2f}MB，跳過處理"
                                )
                                pbar.update(1)
                                # 删除log文件
                                delete_log_file()
                                continue

                        log_debug(f"處理圖片: {image_path}")
                        upscale_result = upscale_image(str(image_path))
