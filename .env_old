COOKIE=

# 大模型配置 - OpenAI兼容格式
# 用於分鏡生成的模型配置
STORYBOARD_API_KEY=sk-T9Ki5vObbywYlNc6lda4dx6rVCvoRf3Y3R8zyIQA3IBdhofG
STORYBOARD_API_URL=https://tbai.xin/v1
STORYBOARD_MODEL=deepseek-r1

# 用於圖片提示詞生成的模型配置
PROMPT_API_KEY=sk-T9Ki5vObbywYlNc6lda4dx6rVCvoRf3Y3R8zyIQA3IBdhofG
PROMPT_API_URL=https://tbai.xin/v1
PROMPT_MODEL=deepseek-v3

# LLM 並發配置
# LLM API 最大並發數
LLM_THREADS=50
# LLM API 請求超時時間(秒)
LLM_TIMEOUT=120
# LLM API 重試次數
LLM_RETRY_ATTEMPTS=3
# 是否開啟詳細日誌
VERBOSE_LOGGING=true

# 備用：阿里雲通義千問配置 (兼容模式)
AL_API_KEY=jojokey
AL_API_URL=https://small-worm-50.deno.dev/api/v1

# 備用：Gemini API配置
GEMINI_API_KEY=
GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# 文生图配置 - 使用 Flux API
FLUX_WIDTH=1024
FLUX_HEIGHT=768
FLUX_MODEL=flux
FLUX_SEED=
FLUX_ENHANCE=false

# 高清修复配置
UPSCALY_ENABLE=false
UPSCAYL_SCALE=4
UPSCAYL_MODEL=realesr-animevideov3-x4
UPSCALY_FILE_TYPE=jpg

# Edge TTS 配置
# Edge TTS 语音
EDGE_TTS_VOICE=zh-CN-YunxiNeural
# 音频生成最大并发数
AUDIO_THREADS=5
# 是否使用异步音频生成
USE_ASYNC_AUDIO=true

# 分段视频生成配置
# 视频生成线程数
VIDEO_THREADS=4         
# 是否是竖屏模式
PORTRAIT_MODE=True
# 视频宽度
VIDEO_WIDTH=1080
# 视频高度
VIDEO_HEIGHT=1920
# 移动距离 倍率
MOVE_DISTANCE=0.2
# 移动速度
MOVE_SPEED=1.0
# 入场效果
ENTRANCE_EFFECT=True
# 入场持续时间
ENTRANCE_DURATION=0.2
# 音频速度 (效果不好)
AUDIO_SPEED=1.0
